# SSO System Environment Variables (Example)
# 실제 운영 및 개발 시 .env 파일로 복사하여 사용하세요.

# -----------------
# 1. 포트 설정 (Port Configuration)
# -----------------
DB_PORT=18001
REDIS_PORT=18002
API_PORT=18003
WEB_PORT=18004

# -----------------
# 2. 데이터베이스 설정 (Database - PostgreSQL)
# -----------------
POSTGRES_USER=lightkey
POSTGRES_PASSWORD=lightkey_sso_secret!
POSTGRES_DB=lightkey_sso
DB_HOST=sso-db

# -----------------
# 3. Redis 설정 (In-Memory Store)
# -----------------
REDIS_HOST=sso-redis
REDIS_PASSWORD=redis_sso_pass!

# -----------------
# 4. 백엔드(IdP API) 전용 환경 변수
# -----------------
# JWT 발급을 위한 강력한 시크릿 키 (openssl rand -base64 32 등으로 생성 추천)
JWT_SECRET=super_secret_jwt_key_sso_example123!
# JWT 수명 설정 예시
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------
# 5. 프론트엔드 전용 환경 변수 (.env.local)
# -----------------
# 클라이언트(브라우저)에서 API 접근 시 사용할 베이스 URL
NEXT_PUBLIC_API_URL=http://localhost:18003
# Next Auth 혹은 인증 쿠키 등을 위한 시크릿
NEXTAUTH_SECRET=super_secret_web_key_sso_example123!
